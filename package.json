{
  "name": "droidpilot-mcp",
  "version": "0.4.0",
  "description": "MCP server for AI agents to build, deploy, and test Android apps",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "droidpilot": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "keywords": [
    "mcp",
    "android",
    "testing",
    "ai-agent",
    "kotlin"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.5.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
